{
  "version": 2,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*).html",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|assets|favicon\\.ico|.*\\.).*)",
      "destination": "/api/index.js"
    }
  ]
}